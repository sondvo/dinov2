    "# Paths and run settings\n",
    "REPO_DIR = Path(\"/home/svo/source/dinov2\")\n",
    "NPY_PATH = Path(\"/scratch/svo/morpho_analysis/SQ00015209/small_original_img_with_mask_quantile.npy\")\n",
